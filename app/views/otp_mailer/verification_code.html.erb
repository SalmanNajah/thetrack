<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #fafafa;
      margin: 0;
      padding: 0;
      color: #18181b;
    }
    .container {
      max-width: 480px;
      margin: 40px auto;
      background-color: #ffffff;
      border-radius: 16px;
      border: 1px solid #e4e4e7;
      overflow: hidden;
    }
    .header {
      padding: 32px 32px 24px;
      text-align: center;
    }
    .header h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
      color: #18181b;
    }
    .body {
      padding: 0 32px 32px;
      text-align: center;
    }
    .body p {
      font-size: 15px;
      line-height: 1.6;
      color: #52525b;
      margin: 0 0 24px;
    }
    .otp-code {
      font-size: 36px;
      font-weight: 700;
      letter-spacing: 0.3em;
      color: #18181b;
      background-color: #f4f4f5;
      border-radius: 12px;
      padding: 16px 24px;
      display: inline-block;
      margin: 0 0 24px;
      font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    }
    .expiry {
      font-size: 13px;
      color: #a1a1aa;
      margin: 0;
    }
    .footer {
      padding: 20px 32px;
      text-align: center;
      border-top: 1px solid #f4f4f5;
    }
    .footer p {
      font-size: 12px;
      color: #a1a1aa;
      margin: 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>TheTrack</h1>
    </div>
    <div class="body">
      <p>Enter this code to verify your email address:</p>
      <div class="otp-code"><%= @code %></div>
      <p class="expiry">This code expires in 10 minutes. If you didn't request this, you can safely ignore this email.</p>
    </div>
    <div class="footer">
      <p>&copy; <%= Date.current.year %> TheTrack. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
