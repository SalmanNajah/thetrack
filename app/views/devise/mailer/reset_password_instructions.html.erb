<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background-color: #fafafa;
      margin: 0;
      padding: 0;
      color: #18181b;
    }
    .container {
      max-width: 480px;
      margin: 40px auto;
      background-color: #ffffff;
      border: 1px solid #e4e4e7;
      overflow: hidden;
    }
    .header {
      padding: 32px 32px 24px;
      text-align: center;
    }
    .header h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
      color: #18181b;
    }
    .body {
      padding: 0 32px 32px;
      text-align: center;
    }
    .body p {
      font-size: 15px;
      line-height: 1.6;
      color: #52525b;
      margin: 0 0 24px;
    }
    .btn-reset {
      font-size: 15px;
      font-weight: 600;
      color: #ffffff !important;
      background-color: #18181b;
      padding: 14px 28px;
      display: inline-block;
      text-decoration: none;
      margin: 12px 0 24px;
    }
    .btn-reset:hover {
      background-color: #27272a;
    }
    .expiry {
      font-size: 13px;
      color: #71717a;
      margin: 24px 0 0;
      text-align: center;
      line-height: 1.6;
    }
    .footer {
      padding: 20px 32px;
      text-align: center;
      border-top: 1px solid #f4f4f5;
    }
    .footer p {
      font-size: 12px;
      color: #a1a1aa;
      margin: 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>TheTrack</h1>
    </div>
    <div class="body">
      <p>We received a request to reset the password for your account (<strong><%= @resource.email %></strong>).</p>
      
      <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" class="btn-reset">
        Reset Password
      </a>

      <p style="font-size: 12px; color: #71717a; margin: 0 0 24px; line-height: 1.5; text-align: center;">
        If the button above doesn't work, copy and paste this URL into your browser:<br>
        <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="color: #2563eb; text-decoration: underline; word-break: break-all;">
          <%= edit_password_url(@resource, reset_password_token: @token) %>
        </a>
      </p>

      <p class="expiry">
        This link is only valid for 15 minutes. If you did not request this password reset, please ignore this email. However, we recommend reviewing your account security if you suspect unauthorized access.
      </p>
    </div>
    <div class="footer">
      <p>&copy; <%= Date.current.year %> TheTrack. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
