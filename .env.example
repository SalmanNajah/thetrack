# Google OAuth Credentials (for Devise + OmniAuth)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Resend (for transactional emails — OTP verification)
RESEND_API_KEY=re_your_api_key_here

# Mailer configuration
# MAILER_FROM=TheTrack <noreply@track.salmannajah.dev>
# APP_HOST=track.salmannajah.dev

# Admin users (comma-separated list of emails auto-promoted to admin on signup)
# ADMIN_EMAILS=admin@example.com,your-email@example.com

# Run Solid Queue worker inside Puma (set to 1 in production for single-server deploys)
# SOLID_QUEUE_IN_PUMA=1
